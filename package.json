{
	"name": "homeassistant-server",
	"version": "2.0.1",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"prepare": "husky",
		"build": "rimraf dist && yarn build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw .",
		"dist": "yarn companion-module-build"
	},
	"license": "MIT",
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"run prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"run lint:raw --fix"
		]
	},
	"engines": {
		"node": "^22.10"
	},
	"dependencies": {
		"@companion-module/base": "^2.0.0",
		"debounce-fn": "^6.0.0",
		"home-assistant-js-websocket": "^9.6.0",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.0",
		"@types/node": "^22.19.13",
		"@types/ws": "^8.18.1",
		"eslint": "^9.39.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-homeassistant-server.git"
	},
	"packageManager": "yarn@4.12.0"
}
